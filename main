#!/bin/bash
set -euo pipefail

# Brainlife runs this script in the task working directory where config.json is present.
# Apps are expected to read config.json and write outputs under ./ in datatype structure. citeturn2view1turn23search5

CONFIG="config.json"
[ -f "$CONFIG" ] || { echo "ERROR: Missing config.json" >&2; exit 1; }

# Parse config with python (avoids jq dependency).
python3 - <<'PY'
import json, os, sys
from pathlib import Path

with open("config.json","r") as f:
    cfg = json.load(f)

# Required paths
tck = cfg.get("tck")
t1  = cfg.get("t1")

if not tck or not Path(tck).exists():
    raise SystemExit(f"ERROR: config['tck'] missing or not found: {tck}")
if not t1 or not Path(t1).exists():
    raise SystemExit(f"ERROR: config['t1'] missing or not found: {t1}")

# Output path (force Brainlife datatype layout)
out_default = "track/track.tck"
track_out = cfg.get("track_out", out_default)

# Enforce that we write inside ./track/ for track/tck datatype
track_out = str(Path("track") / Path(track_out).name)

# Optional params (mirror shell defaults)
perc = cfg.get("perc", None)
smooth_density = bool(cfg.get("smooth_density", True))
length_thr = float(cfg.get("length_thr", 0.90))
N_points = int(cfg.get("N_points", 32))
keep_endpoints = bool(cfg.get("keep_endpoints", False))
average_type = cfg.get("average_type", "mean")
endpoint_mode = cfg.get("endpoint_mode", "median")
representative = bool(cfg.get("representative", False))
spline_smooth = cfg.get("spline_smooth", None)

# Build CLI for bundle_skeleton.py
args = [
    sys.executable, "bundle_skeleton.py",
    tck, track_out, t1,
    "--length-thr", str(length_thr),
    "--n-points", str(N_points),
    "--average-type", average_type,
    "--endpoint-mode", endpoint_mode,
]
if perc is None:
    args += ["--perc", "0"]
else:
    args += ["--perc", str(float(perc))]

args += ["--smooth-density" if smooth_density else "--no-smooth-density"]
if keep_endpoints:
    args += ["--keep-endpoints"]
if representative:
    args += ["--representative"]
if spline_smooth is not None:
    args += ["--spline-smooth", str(float(spline_smooth))]

# Ensure output dir exists
Path("track").mkdir(parents=True, exist_ok=True)

print("Running:", " ".join(args))
os.execv(sys.executable, args)
PY
